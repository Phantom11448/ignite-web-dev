rules_version = '2';

// Firestore security rules for BizCheck.
// Model: every document lives under businesses/{businessId}/... .
// A user can only touch data belonging to a business they're an active
// member of. Beyond that, access is split by role:
//
//   owner       — full access to everything.
//   supervisor  — can manage jobs and categories, log expenses/labor for
//                 anyone, and can log revenue changes (see
//                 revenue_entries below), but cannot see/manage the team
//                 and cannot change business settings. The app's UI
//                 still keeps revenue TOTALS and the profitability panel
//                 owner-only (supervisor logs entries "blind," the same
//                 way crew logs expenses without seeing job totals) —
//                 that's a UI choice, not a rules restriction, since
//                 supervisor needs read access to revenue_entries for
//                 the shared profitability calculation to work at all.
//   crew        — can only log their own expenses (receipts), hours, and
//                 jobsite notes/photos against jobs. Cannot create/edit
//                 jobs, cannot manage categories, cannot edit other
//                 people's entries, and cannot log revenue changes at
//                 all (not even blind).
//
// NOTE: Firestore rules operate on whole documents for reads — they can
// restrict which fields get WRITTEN (e.g. block crew from setting
// revenue), but they cannot redact a single field out of a document a
// lesser role is otherwise allowed to read. The app's UI hides that data
// from supervisor/crew views, and these rules block them from ever
// writing it, but a determined user with direct Firestore access could
// still read raw documents. revenue_entries being its OWN subcollection
// (rather than a field on the job doc, like the old revenue_amount was)
// means a future hardening pass CAN restrict its read access to owner
// only without touching anything else — not done here because it would
// break supervisor's profitability view, which currently depends on
// reading revenue_entries to compute totals it just doesn't display.
//
// SUBSCRIPTION/TRIAL GATING: a business has access to its operational
// data (jobs and everything nested under a job, categories, and the
// bulletin board) only while hasActiveAccess(businessId) is true — either
// subscription_status == 'active' (set by bizcheck-stripe-webhook.js) or
// still within the 30-day trial window measured from the business doc's
// created_at. This is layered ON TOP of the existing role checks above,
// not a replacement for them — every allow condition below keeps its
// original role requirement AND now also requires hasActiveAccess.
// Deliberately NOT gated: the businesses/{businessId} doc itself, users/,
// and user_business_map/ — the app has to keep reading those even while
// locked out, so it can show who's locked out, why, and (for the owner)
// a working Subscribe button.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function memberDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid));
    }

    function isBusinessMember(businessId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid)) &&
        memberDoc(businessId).data.active == true;
    }

    function roleOf(businessId) {
      return memberDoc(businessId).data.role;
    }

    function isOwner(businessId) {
      return isBusinessMember(businessId) && roleOf(businessId) == 'owner';
    }

    function isSupervisorOrAbove(businessId) {
      return isBusinessMember(businessId) && roleOf(businessId) in ['owner', 'supervisor'];
    }

    // --- Subscription/trial access gating ---------------------------------
    // businessDoc/isInTrial/hasActiveAccess mirror the exact logic in
    // app.html's client-side hasAccess() computation — keep both in sync if
    // this ever changes. get() calls that hit the same document path
    // within one rule evaluation are cached by Firestore, so calling
    // businessDoc(businessId) from multiple places below (isInTrial,
    // hasActiveAccess) only costs one actual document read, not several.
    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId));
    }

    // True strictly before the 30-day trial window closes. created_at is a
    // Firestore serverTimestamp() (see signUpOwner in auth.js), so it's
    // already a `timestamp` value here — duration.value(30, 'd') builds a
    // 30-day `duration`, and timestamp + duration is itself a `timestamp`,
    // so this compares two timestamps directly (request.time is also a
    // timestamp — the time the request hit the server).
    function isInTrial(businessId) {
      return request.time < businessDoc(businessId).data.created_at + duration.value(30, 'd');
    }

    function hasActiveAccess(businessId) {
      return businessDoc(businessId).data.subscription_status == 'active' || isInTrial(businessId);
    }

    // Top-level (not nested under businesses/) — lets a logged-in user find
    // which business they belong to. Written once at account creation time
    // by signUpOwner (self) or createTeamMember (owner writing on behalf of
    // a new hire).
    match /user_business_map/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
        (request.auth.uid == userId || isOwner(request.resource.data.business_id));
    }

    // Fields written ONLY by the trusted server context in
    // netlify/functions/bizcheck-stripe-webhook.js, via the Firebase Admin
    // SDK (which bypasses these rules entirely). No client request should
    // ever be allowed to set these, at create OR update time — see the
    // allow create/update conditions below, both of which block them
    // explicitly via this shared list rather than just relying on nobody
    // trying.
    function subscriptionFields() {
      return ['subscription_status', 'stripe_customer_id', 'stripe_subscription_id'];
    }

    match /businesses/{businessId} {
      allow read: if isBusinessMember(businessId);
      // Signup creates this doc with the new owner's own uid as businessId.
      // Also blocks a client from seeding subscription_status/stripe_* at
      // signup time — those three are server-managed only (see
      // subscriptionFields above), so nobody should be able to self-grant
      // "active" by just including it in their own signup write.
      allow create: if isSignedIn() && request.auth.uid == businessId &&
        !request.resource.data.keys().hasAny(subscriptionFields());
      // Owner can update ordinary business fields (name, trade_type, etc.)
      // freely, but subscription_status/stripe_customer_id/
      // stripe_subscription_id can never be part of that update — no
      // client, not even the owner, writes those directly. diff().affectedKeys()
      // looks at exactly which fields an update actually touches, so this
      // only blocks updates that try to include one of the three; every
      // other owner update keeps working normally.
      allow update: if isOwner(businessId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(subscriptionFields());
      allow delete: if isOwner(businessId);

      match /users/{userId} {
        allow read: if isBusinessMember(businessId);
        // A user can create their own profile doc (signup); owners can add others.
        allow create: if isSignedIn() && (request.auth.uid == userId || isOwner(businessId));
        allow update, delete: if isOwner(businessId) || request.auth.uid == userId;
      }

      match /categories/{categoryId} {
        allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
        // Crew can see category names (needed to log an expense) but not
        // create/rename/delete them.
        allow write: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
      }

      // Company-wide Bulletin Board — NOT nested under jobs/, unlike
      // expenses/labor_entries/revenue_entries/job_notes above, since a
      // post isn't tied to any one job. Open to every role: anyone active
      // can read, and anyone active can post (crew included, unlike
      // revenue_entries). Deleting is the one place this differs from
      // job_notes' pattern — here the post's own author can also delete
      // it, not just supervisor/owner, so someone can walk back their own
      // post. Editing is restricted to the author only (supervisor/owner
      // don't get a blanket update here the way they do delete, since
      // silently editing someone else's words is a different kind of
      // action than removing them).
      match /bulletin_posts/{postId} {
        allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
        allow create: if isBusinessMember(businessId) && hasActiveAccess(businessId);
        allow delete: if (isSupervisorOrAbove(businessId) || (isBusinessMember(businessId) && resource.data.posted_by == request.auth.uid)) && hasActiveAccess(businessId);
        allow update: if isBusinessMember(businessId) && resource.data.posted_by == request.auth.uid && hasActiveAccess(businessId);
      }

      match /jobs/{jobId} {
        allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
        // Crew cannot create, edit, complete, or cancel jobs.
        allow create, update: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
        allow delete: if isOwner(businessId) && hasActiveAccess(businessId);

        match /expenses/{expenseId} {
          allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          // Anyone active (including crew) can log a new expense/receipt.
          allow create: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          // Only supervisor/owner can correct an existing entry.
          allow update, delete: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
        }

        match /labor_entries/{laborEntryId} {
          allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          // Anyone active (including crew) can log their own hours.
          allow create: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          allow update, delete: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
        }

        match /revenue_entries/{revenueEntryId} {
          // Read follows the same pattern as categories: any active
          // business member can read (needed so profitability
          // calculations — used by supervisor's expense/labor totals too
          // — don't break), but crew can never write. Unlike expenses/
          // labor_entries, crew doesn't even get create access here —
          // logging a price change is a supervisor/owner-only action.
          allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          allow write: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
        }

        match /job_notes/{noteId} {
          // No dollar figure lives here, so unlike revenue_entries there's
          // no reason to restrict this beyond normal business membership —
          // same open pattern as expenses/labor_entries: anyone active
          // (including crew) can log a note or photo, only supervisor/
          // owner can correct/remove one that's already there.
          allow read: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          allow create: if isBusinessMember(businessId) && hasActiveAccess(businessId);
          allow update, delete: if isSupervisorOrAbove(businessId) && hasActiveAccess(businessId);
        }
      }
    }
  }
}
